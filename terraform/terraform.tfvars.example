# Copy this file to terraform.tfvars and fill in real values.
# terraform.tfvars is git-ignored — never commit it.

hcloud_token = "your-hetzner-api-token"

server_name  = "tour-de-jug"
server_type  = "cx22"        # 2 vCPU / 4 GB RAM / ~5 €/mo
server_image = "ubuntu-24.04"
datacenter   = "nbg1-dc3"    # Nuremberg; alternatives: fsn1-dc14, hel1-dc2, ash-dc1

# Paste the contents of your ~/.ssh/id_ed25519.pub (or whichever key you use)
ssh_public_key = "ssh-ed25519 AAAA... your-comment"

domain      = "tourdegjug.example.com"
alert_email = "you@example.com"

# Sensitive — consider using TF_VAR_* env vars instead of writing these here.
db_password          = "a-strong-random-password"
github_client_id     = "your-github-oauth-app-client-id"
github_client_secret = "your-github-oauth-app-client-secret"
